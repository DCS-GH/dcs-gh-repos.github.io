# Example environment configuration for `npm run build`.
# Copy this file to `.env` and fill in values for local builds:
#   cp .env.example .env
#   npm run build
#
# The build auto-loads `.env` when present (via Node's --env-file-if-exists).
# Real environment variables (e.g. those set in CI) always take precedence.

# GitHub organization to catalog.
ORG_NAME=DCS-GH

# Repo types to list: all | public | private | forks | sources | member.
# "all" only returns private/internal repos when an authenticated token is provided.
REPO_TYPE=all

# Include forked repositories in the catalog.
INCLUDE_FORKS=false

# Title shown on the generated page. Defaults to "<ORG_NAME> Repository Catalog".
CATALOG_TITLE=DCS-GH Repositories

# Token used for GitHub API requests. Required to list private/internal repos
# and to read org custom properties (service owner, lifecycle, etc.).
# Needs scopes: repo (read) and read:org. Never commit a real token.
# CATALOG_GITHUB_TOKEN takes precedence; GH_TOKEN is used as a fallback.
CATALOG_GITHUB_TOKEN=
GH_TOKEN=
